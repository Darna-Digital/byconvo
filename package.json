{
  "name": "reviewer",
  "private": true,
  "version": "0.1.0",
  "description": "reviewer.sh — local git review tool",
  "scripts": {
    "dev": "pnpm --parallel --filter @reviewer/server --filter spa dev",
    "dev:desktop": "pnpm --parallel --filter spa --filter @reviewer/desktop dev",
    "desktop": "pnpm build:desktop && pnpm --filter @reviewer/desktop start",
    "build:desktop": "pnpm --filter @reviewer/server build:bundle && pnpm --filter spa build:desktop && pnpm --filter @reviewer/desktop build",
    "pack:desktop": "pnpm build:desktop && pnpm --filter @reviewer/desktop run pack",
    "dist:desktop": "pnpm build:desktop && pnpm --filter @reviewer/desktop run dist",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r --if-present lint",
    "format:check": "pnpm -r --if-present format:check"
  },
  "packageManager": "pnpm@11.7.0"
}
