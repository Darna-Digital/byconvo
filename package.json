{
  "name": "codediff",
  "private": true,
  "version": "0.1.0",
  "description": "codediff.sh — local git review tool",
  "scripts": {
    "dev": "pnpm --parallel --filter @codediff/core --filter @codediff/client dev",
    "dev:desktop": "pnpm --parallel --filter @codediff/client --filter @codediff/desktop dev",
    "desktop": "pnpm --filter @codediff/client build && pnpm --filter @codediff/core build && pnpm --filter @codediff/desktop start",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@10.33.4"
}
