{
  "name": "reviewer",
  "private": true,
  "version": "0.1.0",
  "description": "reviewer.sh — local git review tool",
  "scripts": {
    "dev": "pnpm --parallel --filter @reviewer/core --filter @reviewer/client dev",
    "dev:desktop": "pnpm --parallel --filter @reviewer/client --filter @reviewer/desktop dev",
    "desktop": "pnpm --filter @reviewer/client build && pnpm --filter @reviewer/core build && pnpm --filter @reviewer/desktop start",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@10.33.4"
}
