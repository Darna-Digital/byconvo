{
  "name": "reviewer",
  "private": true,
  "version": "0.1.0",
  "description": "reviewer.sh — local git review tool",
  "scripts": {
    "dev": "pnpm --parallel --filter @reviewer/server --filter spa dev",
    "dev:desktop": "pnpm --parallel --filter spa --filter @reviewer/desktop dev",
    "desktop": "pnpm --filter spa build && pnpm --filter @reviewer/desktop start",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r --if-present lint",
    "format:check": "pnpm -r --if-present check"
  },
  "packageManager": "pnpm@10.33.4"
}
