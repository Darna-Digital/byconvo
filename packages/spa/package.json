{
  "name": "spa",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "check": "prettier --check \"**/*.{ts,tsx,js,jsx}\"",
    "gen:api": "openapi-typescript http://localhost:41811/api/openapi.json -o src/lib/api/schema.d.ts && perl -0777 -i -pe 's/\\(number \\| \"NaN\" \\| \"Infinity\" \\| \"-Infinity\"\\) \\| \\(\"Infinity\" \\| \"-Infinity\" \\| \"NaN\"\\)/number/g; s/number \\| \"NaN\" \\| \"Infinity\" \\| \"-Infinity\"/number/g;' src/lib/api/schema.d.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@pierre/diffs": "^1.2.10",
    "@pierre/trees": "1.0.0-beta.4",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "latest",
    "@uiw/codemirror-extensions-langs": "^4.25.10",
    "@uiw/codemirror-theme-github": "^4.25.10",
    "@uiw/react-codemirror": "^4.25.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.17.0",
    "openapi-react-query": "^0.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "eslint": "^9",
    "jsdom": "^28",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6",
    "vite": "^8",
    "vitest": "^4"
  }
}
