{
  "name": "@byconvo/desktop",
  "productName": "Byconvo",
  "private": true,
  "version": "0.1.0",
  "description": "byconvo desktop — Electron shell around the client",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json && BYCONVO_DESKTOP_DEV=1 electron .",
    "start": "tsc -p tsconfig.json && electron ."
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.8.0"
  }
}
