{
  "name": "@reviewer/desktop",
  "private": true,
  "version": "0.1.0",
  "description": "reviewer desktop — Electron shell around the client",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json && REVIEWER_DESKTOP_DEV=1 electron .",
    "start": "tsc -p tsconfig.json && electron ."
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "electron": "^42.4.0",
    "typescript": "^5.8.0"
  }
}
