{
  "name": "@byconvo/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "byconvo server — Effect backend (darna-stack pattern), git/filesystem-backed",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "build:bundle": "esbuild src/main.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/main.cjs --sourcemap --external:node-pty",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.74",
    "@types/ws": "^8.18.1",
    "effect": "4.0.0-beta.74",
    "node-pty": "^1.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@byconvo/lint": "workspace:*",
    "@effect/vitest": "4.0.0-beta.74",
    "@types/node": "^22.15.0",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  }
}
