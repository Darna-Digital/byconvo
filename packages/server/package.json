{
  "name": "@reviewer/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "reviewer server — Effect backend (darna-stack pattern), git/filesystem-backed",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.74",
    "better-sqlite3": "^12.10.0",
    "effect": "4.0.0-beta.74"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.74",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  }
}
